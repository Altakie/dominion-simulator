{
  "name": "dominion-simulator",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@types/bun": "latest",
    "@typescript/native-preview": "^7.0.0-dev.20260621.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "scripts": {
    "serve": "bun run --cwd packages/client build; bun run --cwd packages/server src/index.ts",
    "dev": "conc 'bun run --cwd packages/server dev' 'bun run --cwd packages/client watch'",
    "format": "biome format --fix",
    "lint": "biome check --fix",
    "lint:unsafe": "biome check --fix --unsafe",
    "typecheck": "tsgo --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.100.9",
    "concurrently": "^9.2.1",
    "react-router-dom": "^7.15.1"
  }
}
